# Copy to .env and fill in as needed
UPSC_RAG_DATA_DIR=data
UPSC_RAG_PROCESSED_DIR=data/processed

# LLM / embeddings (later)
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small

# LiteLLM AI gateway (optional). Leave UPSC_RAG_LLM_GATEWAY empty for direct OpenAI;
# set to `litellm` to route all CHAT calls through the proxy (embeddings stay direct).
# LITELLM_API_KEY must equal the proxy's LITELLM_MASTER_KEY.
# UPSC_RAG_LLM_GATEWAY=litellm
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_MASTER_KEY=sk-litellm-local
# LITELLM_API_KEY=sk-litellm-local
